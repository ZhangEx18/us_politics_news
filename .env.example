# 新闻分析系统环境变量配置
# 复制此文件为 .env 并填入真实密钥

# NewsAPI (https://newsapi.org/register)
NEWSAPI_KEY=

# TianAPI (https://www.tianapi.com/)
TIANAPI_KEY=

# AI 分析（中文标题+摘要+深度解读）
# 支持 OpenAI 兼容 API（OpenAI、DeepSeek、Moonshot、通义千问等）
AI_PROVIDER=openai
AI_API_KEY=
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4o-mini

# VPS 发布凭据（publish_daily.sh 自动 git push 用）
GIT_PUSH_TOKEN=
GIT_PUSH_REPO=
GIT_PUSH_BRANCH=main
